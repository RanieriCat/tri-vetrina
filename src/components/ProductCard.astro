---
import type { Product } from '@/data/products';
import BuyNowButton from '@/components/BuyNowButton.astro';

const { product } = Astro.props as { product: Product };
const decodeHtmlEntities = (value: string) =>
  value
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&apos;/gi, "'")
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>');

const normalizeText = (value: string) =>
  decodeHtmlEntities(value)
    .replace(/\u00a0/g, ' ')
    .replace(/[ \t]+\n/g, '\n')
    .replace(/\n[ \t]+/g, '\n')
    .replace(/[ \t]{2,}/g, ' ')
    .trim();

const firstDescriptionFromHtml = (value: string) =>
  normalizeText(
    value
      .replace(/<\s*br\s*\/?>/gi, '\n')
      .replace(/<\/(p|div|section|article|blockquote|h1|h2|h3|h4|h5|h6|ul|ol)>/gi, '\n\n')
      .replace(/<li\b[^>]*>/gi, '- ')
      .replace(/<\/li>/gi, '\n')
      .replace(/<[^>]+>/g, '')
  )
    .split(/\r?\n\s*\r?\n+/)
    .map((section) => section.split(/\r?\n+/).map((line) => line.trim()).filter(Boolean))
    .find((section) => section.length)?.join(' ');

const firstDescriptionFromText = (value: string) =>
  normalizeText(value)
    .split(/\r?\n\s*\r?\n+/)
    .map((section) => section.split(/\r?\n+/).map((line) => line.trim()).filter(Boolean))
    .find((section) => section.length)?.join(' ');

const firstDescription =
  firstDescriptionFromHtml(product.descriptionHtml) ??
  firstDescriptionFromText(product.shortDescription) ??
  product.name;
---
<article class="card product-card hover-lift" data-reveal>
  <img
    src={product.image}
    alt={product.name}
    width="600"
    height="380"
    loading="lazy"
    decoding="async"
    style="aspect-ratio: 4 / 3; object-fit: cover;"
  />

  <h3>{product.name}</h3>
  <p>{firstDescription}</p>
  <p><strong>EUR {product.price.toFixed(2)}</strong></p>

  <div class="hero-actions">
    <a class="btn btn--ghost" href={`/shop/products/${product.slug}`}>Scopri</a>
    {product.variantId ? <BuyNowButton variantId={product.variantId} /> : null}
    <button
      class="btn add-to-cart"
      data-slug={product.slug}
      data-name={product.name}
      data-price={String(product.price)}
      data-category={product.category}
      data-image={product.image}
      data-short-description={product.shortDescription}
      data-inci={product.inci}
      data-variant-id={product.variantId ?? ''}
      data-variant-title={product.variantTitle ?? ''}
      type="button"
    >
      Aggiungi al carrello
    </button>
  </div>
</article>
