---
import type { TemplateKey } from '@/config/templates';

const { template } = Astro.props as { template: TemplateKey };
const gradientId = `hero-gradient-${template}`;

const meta = {
  doctor: {
    badge: 'Cardio focus',
    caption: 'Visual demo orientato a chiarezza e prevenzione.'
  },
  shop: {
    badge: 'Skin routine',
    caption: 'Visual demo orientato a texture e benessere quotidiano.'
  },
  psy: {
    badge: 'Calm space',
    caption: 'Visual demo orientato a ascolto, ritmo e continuita.'
  }
}[template];
---
<aside class="hero-visual card hover-lift" aria-hidden="true" data-reveal>
  <svg viewBox="0 0 380 300" role="presentation" focusable="false">
    <defs>
      <linearGradient id={gradientId} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0.38"></stop>
        <stop offset="100%" stop-color="currentColor" stop-opacity="0.08"></stop>
      </linearGradient>
    </defs>
    <circle cx="190" cy="150" r="120" fill={`url(#${gradientId})`}></circle>

    {template === 'doctor' && (
      <g>
        <path d="M42 160h62l24-44 30 86 26-52h72" fill="none" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"></path>
        <circle cx="116" cy="102" r="18" fill="currentColor" opacity="0.2"></circle>
        <circle cx="268" cy="210" r="14" fill="currentColor" opacity="0.2"></circle>
      </g>
    )}

    {template === 'shop' && (
      <g>
        <rect x="94" y="106" width="192" height="122" rx="32" fill="none" stroke="currentColor" stroke-width="10"></rect>
        <path d="M190 68c19 24 42 45 42 66a42 42 0 1 1-84 0c0-21 23-42 42-66Z" fill="none" stroke="currentColor" stroke-width="10"></path>
        <path d="M120 154h140" stroke="currentColor" stroke-width="10" stroke-linecap="round"></path>
      </g>
    )}

    {template === 'psy' && (
      <g>
        <circle cx="190" cy="150" r="88" fill="none" stroke="currentColor" stroke-opacity="0.35" stroke-width="10"></circle>
        <path d="M92 184c28-48 60-70 98-70s70 22 98 70" fill="none" stroke="currentColor" stroke-width="10" stroke-linecap="round"></path>
        <path d="M92 142c28-33 60-49 98-49s70 16 98 49" fill="none" stroke="currentColor" stroke-width="10" stroke-linecap="round"></path>
        <circle cx="190" cy="150" r="14" fill="currentColor"></circle>
      </g>
    )}
  </svg>
  <div class="floating-element">{meta.badge}</div>
  <p class="hero-visual__caption">{meta.caption}</p>
</aside>
