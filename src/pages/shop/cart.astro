---
import MainLayout from '@/layouts/MainLayout.astro';
import { shopFooterHtml } from '@/config/shop';
import { cartScript } from '@/utils/cart';
---
<MainLayout template="shop" title="Carrello | Lifestyle e Creme" description="Gestisci il tuo carrello demo." footerHtml={shopFooterHtml}>
  <section class="section container" data-reveal>
    <div class="section-head">
      <p class="eyebrow">Carrello</p>
      <h1>Carrello</h1>
      <p class="section-intro">Controlla quantita, totale e prosegui al checkout demo.</p>
    </div>

    <div id="cart-list" class="grid"></div>
    <p id="cart-total" style="font-size: 1.2rem;" aria-live="polite"></p>
    <a class="btn" href="/shop/checkout">Vai al checkout</a>
  </section>

  <script is:inline set:html={cartScript}></script>
  <script is:inline>
    (() => {
      const container = document.getElementById('cart-list');
      const totalEl = document.getElementById('cart-total');
      if (!(container instanceof HTMLElement) || !(totalEl instanceof HTMLElement)) return;

      const update = (index, delta) => {
        const cart = window.shopCart.readCart();
        cart[index].qty += delta;
        if (cart[index].qty <= 0) cart.splice(index, 1);
        window.shopCart.writeCart(cart);
        render();
      };

      const removeItem = (index) => {
        const cart = window.shopCart.readCart();
        cart.splice(index, 1);
        window.shopCart.writeCart(cart);
        render();
      };

      const render = () => {
        const cart = window.shopCart.readCart();

        if (!cart.length) {
          container.innerHTML = '<p class="card">Il carrello e vuoto.</p>';
          totalEl.textContent = 'Totale: EUR 0.00';
          return;
        }

        container.innerHTML = cart
          .map(
            (item, index) => `
              <article class="card" style="display:grid;grid-template-columns:1fr auto;gap:.8rem;align-items:center;">
                <div>
                  <h3>${item.name}${item.variant ? ` · ${item.variant}` : ''}</h3>
                  <p>EUR ${item.price.toFixed(2)} x ${item.qty}</p>
                </div>
                <div class="hero-actions">
                  <button class="btn btn--ghost" type="button" data-dec="${index}">-</button>
                  <button class="btn btn--ghost" type="button" data-inc="${index}">+</button>
                  <button class="btn btn--ghost" type="button" data-rem="${index}">Rimuovi</button>
                </div>
              </article>`
          )
          .join('');

        const total = cart.reduce((sum, item) => sum + item.price * item.qty, 0);
        totalEl.textContent = `Totale: EUR ${total.toFixed(2)}`;

        container.querySelectorAll('[data-inc]').forEach((btn) => {
          btn.addEventListener('click', () => update(btn.dataset.inc, 1));
        });
        container.querySelectorAll('[data-dec]').forEach((btn) => {
          btn.addEventListener('click', () => update(btn.dataset.dec, -1));
        });
        container.querySelectorAll('[data-rem]').forEach((btn) => {
          btn.addEventListener('click', () => removeItem(btn.dataset.rem));
        });
      };

      render();
    })();
  </script>
</MainLayout>
