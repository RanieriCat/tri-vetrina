---
import MainLayout from '@/layouts/MainLayout.astro';
import { shopFooterHtml } from '@/config/shop';
import { cartScript } from '@/utils/cart';
---
<MainLayout template="shop" title="Checkout | Lifestyle & Beauty" description="Checkout in 3 passaggi con validazione base e conferma finale." footerHtml={shopFooterHtml}>
  <section class="section container" data-reveal>
    <div class="section-head">
      <p class="eyebrow">Checkout</p>
      <h1>Checkout</h1>
      <p class="section-intro">Completa i dati, controlla il riepilogo e conferma l ordine in 3 passaggi.</p>
    </div>

    <div id="step-shipping" class="card" data-reveal>
      <h2>1. Dati spedizione</h2>
      <form id="shipping-form" class="grid md-2" novalidate>
        <label>Nome <input required name="nome" autocomplete="given-name" /></label>
        <label>Cognome <input required name="cognome" autocomplete="family-name" /></label>
        <label>Indirizzo <input required name="indirizzo" autocomplete="street-address" /></label>
        <label>Citta <input required name="citta" autocomplete="address-level2" /></label>
        <label>CAP <input required name="cap" autocomplete="postal-code" /></label>
        <label>Telefono <input required name="telefono" autocomplete="tel" /></label>
        <button class="btn" type="submit">Continua</button>
      </form>
    </div>

    <div id="step-review" class="card" hidden data-reveal>
      <h2>2. Riepilogo ordine</h2>
      <div id="checkout-summary"></div>
      <button class="btn" id="confirm-order" type="button">Conferma ordine</button>
    </div>

    <div id="step-confirm" class="card" hidden data-reveal>
      <h2>3. Conferma</h2>
      <p>Grazie! Ordine demo registrato. Riceverai una email di conferma.</p>
      <a class="btn" href="/shop/products">Torna ai prodotti</a>
    </div>
  </section>

  <script is:inline set:html={cartScript}></script>
  <script is:inline>
    (() => {
      const shippingForm = document.getElementById('shipping-form');
      const review = document.getElementById('step-review');
      const confirm = document.getElementById('step-confirm');
      const summary = document.getElementById('checkout-summary');

      if (!(shippingForm instanceof HTMLFormElement)) return;
      if (!(review instanceof HTMLElement) || !(confirm instanceof HTMLElement) || !(summary instanceof HTMLElement)) return;

      const renderSummary = () => {
        const cart = window.shopCart.readCart();
        const total = cart.reduce((sum, item) => sum + item.price * item.qty, 0);

        summary.innerHTML = cart.length
          ? `<ul>${cart
              .map((item) => `<li>${item.name}${item.variant ? ` (${item.variant})` : ''} x ${item.qty} - EUR ${(item.price * item.qty).toFixed(2)}</li>`)
              .join('')}</ul><p><strong>Totale EUR ${total.toFixed(2)}</strong></p>`
          : '<p>Carrello vuoto. Aggiungi prodotti prima di continuare.</p>';
      };

      shippingForm.addEventListener('submit', (event) => {
        event.preventDefault();
        if (!shippingForm.checkValidity()) {
          shippingForm.reportValidity();
          return;
        }

        renderSummary();
        review.hidden = false;
        review.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      document.getElementById('confirm-order')?.addEventListener('click', () => {
        window.shopCart.writeCart([]);
        confirm.hidden = false;
        confirm.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    })();
  </script>
</MainLayout>
