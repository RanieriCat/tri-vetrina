---
import MainLayout from '@/layouts/MainLayout.astro';
import { shopFooterHtml } from '@/config/shop';
const slug = Astro.url.pathname.split('/').pop();
const titles = {
  privacy: 'Privacy Policy',
  terms: 'Termini e Condizioni',
  cookies: 'Cookie Policy',
  'shipping-returns': 'Spedizioni e Resi'
};
const title = titles[slug] ?? 'Informativa';
---
<MainLayout template="shop" title={`${title} | Lifestyle e Creme`} description={`${title} dello shop demo.`} footerHtml={shopFooterHtml}>
  <section class="section container">
    <h1>{title}</h1>
    <div class="card">
      <p>Questa è una pagina informativa demo con struttura realistica.</p>
      <p>Raccogliamo esclusivamente dati necessari a finalità di servizio simulate, senza alcun trattamento reale.</p>
      <p>Per richieste amministrative: legal@lifestyle-creme.demo.</p>
    </div>
  </section>
</MainLayout>
