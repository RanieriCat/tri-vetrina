---
import MainLayout from '@/layouts/MainLayout.astro';
import { shopFooterHtml } from '@/config/shop';
const slug = Astro.url.pathname.split('/').pop();
const titles = {
  privacy: 'Privacy Policy',
  terms: 'Termini e Condizioni',
  cookies: 'Cookie Policy',
  'shipping-returns': 'Spedizioni e Resi'
};
const title = titles[slug] ?? 'Informativa';
---
<MainLayout template="shop" title={`${title} | Lifestyle & Beauty`} description={`${title} della vetrina lifestyle demo.`} footerHtml={shopFooterHtml}>
  <section class="section container">
    <h1>{title}</h1>
    <div class="card">
      <p>Questa pagina e una demo informativa con struttura realistica.</p>
      <p>Eventuali dati inseriti vengono usati solo per simulare i flussi di servizio e non per trattamenti reali.</p>
      <p>Contatto amministrativo demo: legal@lifestyle-creme.demo.</p>
    </div>
  </section>
</MainLayout>
