---
import MainLayout from '@/layouts/MainLayout.astro';
import { products } from '@/data/products';
import { cartScript } from '@/utils/cart';
import { shopFooterHtml } from '@/config/shop';

export const getStaticPaths = () => products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
const { product } = Astro.props;
---
<MainLayout footerHtml={shopFooterHtml} template="shop" title={`${product.name} | Lifestyle e Creme`} description={product.shortDescription}>
  <section class="section container grid md-2">
    <img src={product.image} alt={product.name} class="card" style="width:100%;aspect-ratio:4/3;object-fit:cover;" />
    <div class="card">
      <p style="color:var(--muted);">{product.category}</p>
      <h1>{product.name}</h1>
      <p>{product.shortDescription}</p>
      <p><strong>€ {product.price.toFixed(2)}</strong></p>
      <h2>Ingredienti / INCI</h2>
      <p>{product.inci}</p>
      <button class="btn" id="detail-add" data-product={JSON.stringify(product)}>Aggiungi al carrello</button>
    </div>
  </section>
  <script is:inline set:html={cartScript}></script>
  <script is:inline>
    document.getElementById('detail-add')?.addEventListener('click', (event) => {
      window.shopCart.addToCart(JSON.parse(event.currentTarget.dataset.product));
    });
  </script>
</MainLayout>
