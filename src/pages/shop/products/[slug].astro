---
import MainLayout from '@/layouts/MainLayout.astro';
import { cartScript } from '@/utils/cart';
import { shopFooterHtml } from '@/config/shop';
import { getShopProducts } from '@/lib/shopify';
import BuyNowButton from '@/components/BuyNowButton.astro';

export const getStaticPaths = async () => {
  const products = await getShopProducts({ first: 60 });
  return products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
};
const { product } = Astro.props;
const isShopifyProduct = product.source === 'shopify';
const rawDescription =
  isShopifyProduct && product.shortDescription.trim() !== 'Descrizione non disponibile.'
    ? product.shortDescription
    : '';
const rawDescriptionHtml = isShopifyProduct ? product.descriptionHtml.trim() : '';
const productVideos = product.source === 'shopify' ? product.videos : [];
const galleryImages = product.source === 'shopify' ? product.galleryImages : [];
const mediaThumbFallback = galleryImages[0]?.url || product.image;
const mediaSlides = [
  ...galleryImages.map((image, index) => ({
    mediaType: 'image' as const,
    url: image.url,
    altText: image.altText || `${product.name} immagine ${index + 1}`,
    width: image.width ?? 1200,
    height: image.height ?? 1500,
    thumbUrl: image.url,
    thumbLabel: `Immagine ${index + 1}`,
    thumbType: 'IMG'
  })),
  ...productVideos.map((video, index) => ({
    mediaType: 'video' as const,
    videoKind: video.kind,
    url: video.url,
    altText: video.altText || `${product.name} video ${index + 1}`,
    poster: video.poster || mediaThumbFallback,
    mimeType: video.kind === 'hosted' ? video.mimeType ?? 'video/mp4' : undefined,
    thumbUrl: video.poster || mediaThumbFallback,
    thumbLabel: `Video ${index + 1}`,
    thumbType: 'VIDEO'
  }))
];
const hasMedia = mediaSlides.length > 0;
const decodeHtmlEntities = (value: string) =>
  value
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&apos;/gi, "'")
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>');

const normalizeSectionText = (value: string) =>
  decodeHtmlEntities(value)
    .replace(/\u00a0/g, ' ')
    .replace(/[ \t]+\n/g, '\n')
    .replace(/\n[ \t]+/g, '\n')
    .replace(/[ \t]{2,}/g, ' ')
    .trim();

const splitTextIntoSections = (value: string) =>
  normalizeSectionText(value)
    .split(/\r?\n\s*\r?\n+/)
    .map((section) => section.split(/\r?\n+/).map((line) => line.trim()).filter(Boolean))
    .filter((section) => section.length > 0);

const splitHtmlIntoSections = (value: string) => {
  if (!value.trim()) return [];

  const normalized = normalizeSectionText(
    value
      .replace(/<\s*br\s*\/?>/gi, '\n')
      .replace(/<li\b[^>]*>/gi, '- ')
      .replace(/<\/li>/gi, '\n')
      .replace(/<\/(p|div|section|article|blockquote|h1|h2|h3|h4|h5|h6|ul|ol)>/gi, '\n\n')
      .replace(/<[^>]+>/g, '')
  );

  return splitTextIntoSections(normalized);
};

const descriptionSections = splitHtmlIntoSections(rawDescriptionHtml);
const resolvedDescriptionSections = descriptionSections.length ? descriptionSections : splitTextIntoSections(rawDescription);
const reviewStartRegex = /^\s*\{?\s*"?nome"?\s*:/i;
const reviewFieldRegex = /^"?([^":]+)"?\s*:\s*(.+)$/;
const reviewFieldGlobalRegex = /"?([^":]+)"?\s*:\s*("(?:[^"\\]|\\.)*"|[^,;]+)(?:[,;]|$)/g;

type ReviewCard = {
  name: string;
  body: string[];
  rating?: string;
  meta: string[];
};

const cleanReviewValue = (value: string) =>
  value
    .trim()
    .replace(/^[,;]+|[,;]+$/g, '')
    .replace(/^"(.*)"$/, '$1')
    .trim();

const parseReviewBlock = (lines: string[]): ReviewCard | null => {
  const fields = new Map<string, string>();
  const looseLines: string[] = [];

  lines.forEach((line) => {
    let matchedInlineField = false;
    reviewFieldGlobalRegex.lastIndex = 0;
    const compactLine = line.replace(/[{}]/g, ' ').trim();

    for (const match of compactLine.matchAll(reviewFieldGlobalRegex)) {
      const key = match[1].trim().toLowerCase();
      const value = cleanReviewValue(match[2]);
      if (!value) continue;
      fields.set(key, value);
      matchedInlineField = true;
    }

    if (matchedInlineField) return;

    const match = line.match(reviewFieldRegex);
    if (!match) {
      if (line.trim()) looseLines.push(line.trim());
      return;
    }

    const key = match[1].trim().toLowerCase();
    const value = cleanReviewValue(match[2]);
    if (!value) return;
    fields.set(key, value);
  });

  const name = fields.get('nome');
  if (!name) return null;

  const body = [fields.get('recensione'), fields.get('testo'), fields.get('commento'), ...looseLines].filter(
    (value): value is string => Boolean(value && value.trim())
  );
  const meta = Array.from(fields.entries())
    .filter(([key]) => !['nome', 'recensione', 'testo', 'commento', 'voto', 'rating', 'stelle'].includes(key))
    .map(([key, value]) => `${key}: ${value}`);
  const rating = fields.get('voto') ?? fields.get('rating') ?? fields.get('stelle') ?? undefined;

  return {
    name,
    body,
    rating,
    meta
  };
};

const partitionSections = (sections: string[][]) => {
  const description: string[][] = [];
  const reviews: ReviewCard[] = [];

  sections.forEach((section) => {
    if (!section.length) return;

    let currentDescription: string[] = [];
    let currentReviewLines: string[] = [];

    const flushDescription = () => {
      if (currentDescription.length) {
        description.push([...currentDescription]);
        currentDescription = [];
      }
    };

    const flushReview = () => {
      if (!currentReviewLines.length) return;
      const parsed = parseReviewBlock(currentReviewLines);
      if (parsed) reviews.push(parsed);
      else description.push([...currentReviewLines]);
      currentReviewLines = [];
    };

    section.forEach((line) => {
      if (reviewStartRegex.test(line)) {
        flushDescription();
        flushReview();
        currentReviewLines = [line];
        return;
      }

      if (currentReviewLines.length) {
        currentReviewLines.push(line);
        return;
      }

      currentDescription.push(line);
    });

    flushDescription();
    flushReview();
  });

  return { description, reviews };
};

const { description: contentSections, reviews } = partitionSections(resolvedDescriptionSections);
const summarySection = contentSections[0] ?? [];
const descriptionCardSections = contentSections.slice(1);
const inlineSummarySection = summarySection;
const seoDescription = summarySection.join(' ') || product.name;
const pdpTopClassName = ['section container shop-pdp-top', !hasMedia && 'shop-pdp-top--single']
  .filter(Boolean)
  .join(' ');
const stickyWrapClassName = ['shop-sticky-wrap', 'shop-sticky-wrap--compact'].join(' ');
---
<MainLayout footerHtml={shopFooterHtml} template="shop" title={`${product.name} | Lifestyle & Beauty`} description={seoDescription}>
  <div class="shop-page">
    <section class={pdpTopClassName} data-reveal>
      {hasMedia ? (
        <div class="shop-pdp-media-stack">
          <article class="card shop-gallery-panel shop-media-carousel" data-gallery data-reveal tabindex="0">
            <div class="shop-media-head">
              <p class="eyebrow">Media</p>
              <h2>Immagini e video prodotto</h2>
            </div>

            <div class="shop-gallery-stage">
              {mediaSlides.map((slide, index) => (
                <figure
                  class:list={[
                    'shop-gallery-slide',
                    slide.mediaType === 'video' && 'shop-gallery-slide--video',
                    index === 0 && 'is-active'
                  ]}
                  data-gallery-slide
                  data-gallery-index={String(index)}
                  aria-hidden={index === 0 ? 'false' : 'true'}
                  hidden={index !== 0}
                >
                  {slide.mediaType === 'image' ? (
                    <img
                      src={slide.url}
                      alt={slide.altText}
                      width={slide.width}
                      height={slide.height}
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  ) : slide.videoKind === 'hosted' ? (
                    <video controls playsinline preload="metadata" poster={slide.poster}>
                      <source src={slide.url} type={slide.mimeType} />
                    </video>
                  ) : (
                    <iframe
                      src={slide.url}
                      title={slide.altText}
                      loading="lazy"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                    ></iframe>
                  )}
                </figure>
              ))}
            </div>

            {mediaSlides.length > 1 ? (
              <>
                <div class="shop-gallery-toolbar">
                  <p class="shop-gallery-count" data-gallery-count>1 / {mediaSlides.length}</p>
                  <div class="shop-gallery-actions">
                    <button class="btn btn--ghost shop-gallery-nav" type="button" data-gallery-prev aria-label="Media precedente">Prec</button>
                    <button class="btn btn--ghost shop-gallery-nav" type="button" data-gallery-next aria-label="Media successivo">Succ</button>
                  </div>
                </div>

                <div class="shop-gallery-thumbs" aria-label="Anteprime media prodotto">
                  {mediaSlides.map((slide, index) => (
                    <button
                      class="shop-gallery-thumb"
                      type="button"
                      data-gallery-thumb
                      data-gallery-index={String(index)}
                      aria-label={`Apri ${slide.thumbLabel.toLowerCase()}`}
                      aria-pressed={index === 0 ? 'true' : 'false'}
                    >
                      <span class="shop-gallery-thumb-media">
                        <img
                          src={slide.thumbUrl}
                          alt=""
                          width="160"
                          height="160"
                          loading="lazy"
                          decoding="async"
                        />
                        <span class="shop-gallery-thumb-type">{slide.thumbType}</span>
                      </span>
                      <span class="shop-gallery-thumb-label">{slide.thumbLabel}</span>
                    </button>
                  ))}
                </div>
              </>
            ) : null}
          </article>
        </div>
      ) : null}

      <article class="card shop-pdp-buy" data-reveal>
        {isShopifyProduct && product.category ? <p class="eyebrow">{product.category}</p> : null}
        <h1>{product.name}</h1>
        {inlineSummarySection.map((line) => <p>{line}</p>)}

        <p><strong>EUR {product.price.toFixed(2)}</strong></p>

        <div class="hero-actions">
          <button
            class="btn"
            id="detail-add"
            data-slug={product.slug}
            data-name={product.name}
            data-price={String(product.price)}
            data-category={product.category}
            data-image={product.image}
            data-short-description={product.shortDescription}
            data-inci={product.inci}
            data-variant-id={product.variantId ?? ''}
            data-variant-title={product.variantTitle ?? ''}
            type="button"
          >
            Aggiungi al carrello
          </button>
          {product.variantId ? <BuyNowButton variantId={product.variantId} className="btn btn--ghost" /> : <a class="btn btn--ghost" href="/shop/cart">Vai al carrello</a>}
        </div>

        <p id="detail-status" class="wizard-status" aria-live="polite"></p>
      </article>
    </section>

    {descriptionCardSections.length ? (
      <section class="section container" data-reveal>
        <div class="shop-description-grid">
          {descriptionCardSections.map((section) => (
            <article class="card shop-description-card" data-reveal>
              {section.map((line) => <p>{line}</p>)}
            </article>
          ))}
        </div>
      </section>
    ) : null}

    {reviews.length ? (
      <section class="section container" data-reveal>
        <div class="section-head">
          <p class="eyebrow">Recensioni</p>
          <h2>Recensioni recuperate da Shopify</h2>
        </div>

        <div class="shop-reviews-grid">
          {reviews.map((review) => (
            <article class="card shop-review-card" data-reveal>
              <div class="shop-review-head">
                <div class="shop-review-author">
                  <div class="shop-review-avatar" aria-hidden="true">
                    {review.name.slice(0, 1).toUpperCase()}
                  </div>
                  <div class="shop-review-author-copy">
                    <h3>{review.name}</h3>
                    {review.meta.length ? <p class="muted shop-review-meta">{review.meta.join(' · ')}</p> : null}
                  </div>
                </div>
                {review.rating ? <p class="shop-review-rating">{review.rating}</p> : null}
              </div>
              <div class="shop-review-body">
                {review.body.map((line) => (
                  <p>{line}</p>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : null}
  </div>

  <div class="shop-sticky-atc" role="region" aria-label="Aggiungi al carrello rapido">
    <div class={stickyWrapClassName}>
      <button class="btn" id="sticky-add" type="button">Aggiungi</button>
    </div>
  </div>

  <script is:inline set:html={cartScript}></script>
  <script is:inline>
    (() => {
      const productButton = document.getElementById('detail-add');
      const stickyButton = document.getElementById('sticky-add');
      const status = document.getElementById('detail-status');
      const ensureCartApi = () => {
        if (window.shopCart && typeof window.shopCart.addToCart === 'function') return window.shopCart;

        const key = 'shop-cart';
        const readCart = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(key) || '[]');
            return Array.isArray(parsed) ? parsed : [];
          } catch {
            return [];
          }
        };
        const writeCart = (cart) => localStorage.setItem(key, JSON.stringify(Array.isArray(cart) ? cart : []));
        const itemKey = (item) => [item.slug, item.variant || 'base'].join('::');
        const addToCart = (product) => {
          const cart = readCart();
          const found = cart.find((item) => itemKey(item) === itemKey(product));
          if (found) found.qty = (Number(found.qty) || 1) + 1;
          else cart.push({ ...product, qty: 1 });
          writeCart(cart);
        };

        window.shopCart = { readCart, writeCart, addToCart };
        return window.shopCart;
      };
      const parsePayload = (button) => {
        try {
          const parsed = JSON.parse(button.dataset.product || '{}');
          if (parsed && parsed.slug) return parsed;
        } catch {
          // Fallback to dataset fields below.
        }

        const slug = (button.dataset.slug || '').trim();
        if (!slug) return null;

        return {
          slug,
          name: button.dataset.name || slug,
          price: Number.parseFloat(button.dataset.price || '0'),
          category: button.dataset.category || '',
          image: button.dataset.image || '',
          shortDescription: button.dataset.shortDescription || '',
          inci: button.dataset.inci || '',
          variantId: button.dataset.variantId || undefined,
          variantTitle: button.dataset.variantTitle || undefined
        };
      };

      const addCurrentProduct = () => {
        if (!(productButton instanceof HTMLButtonElement)) return;

        try {
          const payload = parsePayload(productButton);
          if (!payload) throw new Error('Invalid product payload');
          ensureCartApi().addToCart(payload);
          if (status) status.textContent = `${payload.name} aggiunto al carrello.`;
        } catch {
          if (status) status.textContent = 'Errore: impossibile aggiungere il prodotto al carrello.';
        }
      };

      productButton?.addEventListener('click', () => addCurrentProduct());
      stickyButton?.addEventListener('click', () => addCurrentProduct());

      const galleryRoot = document.querySelector('[data-gallery]');
      if (galleryRoot instanceof HTMLElement) {
        const slides = Array.from(galleryRoot.querySelectorAll('[data-gallery-slide]'));
        const thumbs = Array.from(galleryRoot.querySelectorAll('[data-gallery-thumb]'));
        const prevButton = galleryRoot.querySelector('[data-gallery-prev]');
        const nextButton = galleryRoot.querySelector('[data-gallery-next]');
        const counter = galleryRoot.querySelector('[data-gallery-count]');
        let currentIndex = 0;

        const renderGallery = (nextIndex) => {
          if (!slides.length) return;
          currentIndex = (nextIndex + slides.length) % slides.length;

          slides.forEach((slide, index) => {
            const isActive = index === currentIndex;
            slide.toggleAttribute('hidden', !isActive);
            slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
            slide.classList.toggle('is-active', isActive);
          });

          thumbs.forEach((thumb, index) => {
            if (thumb instanceof HTMLButtonElement) {
              thumb.setAttribute('aria-pressed', index === currentIndex ? 'true' : 'false');
            }
          });

          if (counter) counter.textContent = `${currentIndex + 1} / ${slides.length}`;
        };

        if (prevButton instanceof HTMLButtonElement) {
          prevButton.addEventListener('click', () => renderGallery(currentIndex - 1));
        }

        if (nextButton instanceof HTMLButtonElement) {
          nextButton.addEventListener('click', () => renderGallery(currentIndex + 1));
        }

        thumbs.forEach((thumb, index) => {
          if (!(thumb instanceof HTMLButtonElement)) return;
          thumb.addEventListener('click', () => renderGallery(index));
        });

        galleryRoot.addEventListener('keydown', (event) => {
          if (!(event instanceof KeyboardEvent)) return;
          if (event.key === 'ArrowLeft') {
            event.preventDefault();
            renderGallery(currentIndex - 1);
          }
          if (event.key === 'ArrowRight') {
            event.preventDefault();
            renderGallery(currentIndex + 1);
          }
        });

        renderGallery(0);
      }
    })();
  </script>
</MainLayout>
