---
import MainLayout from '@/layouts/MainLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import { cartScript } from '@/utils/cart';
import { getShopProducts } from '@/lib/shopify';
import { shopFooterHtml } from '@/config/shop';

const products = await getShopProducts({ first: 24 });
const featured = products.slice(0, 6);
const dropDateISO = '2026-04-30T20:00:00+02:00';
---
<MainLayout footerHtml={shopFooterHtml} template="shop" title="Lifestyle & Beauty" description="Skincare guidata con quiz routine, consigli personalizzati e acquisto rapido.">
  <div class="shop-page">
    <section class="section container shop-bridge" data-reveal>
      <div class="shop-bridge-grid">
        <article class="shop-bridge-copy card">
          <p class="eyebrow">Lifestyle & Beauty</p>
          <h1>Skincare guidata, acquisto senza attrito.</h1>
          <p class="section-intro">Dalla scoperta su social alla selezione prodotto in pochi passaggi: contenuti coerenti, scelta guidata e checkout semplice.</p>

          <ul class="shop-social-pills" aria-label="As seen on social">
            <li class="logo-pill logo-pill--social logo-pill--tiktok">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
              <span>As seen on TikTok</span>
            </li>
            <li class="logo-pill logo-pill--social logo-pill--instagram">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077"/>
              </svg>
              <span>As seen on Instagram</span>
            </li>
            <li class="logo-pill logo-pill--social logo-pill--pinterest">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
              </svg>
              <span>As seen on Pinterest</span>
            </li>
          </ul>

          <div class="hero-actions">
            <a class="btn" href="#routine-quiz">Trova la tua routine</a>
            <a class="btn btn--ghost" href="/shop/products">Vai al catalogo</a>
          </div>

          <p class="shop-soft-proof" id="shop-proof-soft" aria-live="polite">Oggi XX persone hanno acquistato una routine skincare (dato demo).</p>
        </article>

        <article class="shop-bridge-media card" data-reveal>
          <img
            src="https://images.pexels.com/photos/3851790/pexels-photo-3851790.jpeg?auto=compress&cs=tinysrgb&fit=crop&w=1400&h=980"
            alt="Creator beauty durante applicazione prodotto"
            width="1400"
            height="980"
            loading="eager"
            decoding="async"
          />
          <div class="shop-clip-card">
            <video controls playsinline preload="metadata" poster="https://images.pexels.com/videos/8996176/free-video-8996176.jpg?fit=crop&w=900&h=1600&auto=compress&cs=tinysrgb">
              <source src="https://videos.pexels.com/video-files/8996176/8996176-hd_1080_1920_25fps.mp4" type="video/mp4" />
            </video>
            <div>
              <p><strong>Clip social 18s</strong></p>
              <p class="muted">Texture test e applicazione reale in formato verticale acquistabile.</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section id="routine-quiz" class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Routine guidata</p>
        <h2>Quiz rapido con raccomandazioni utili</h2>
        <p class="section-intro">Rispondi a 4 domande su pelle, obiettivo, texture e preferenze: ottieni routine mattina/sera, bundle e alternative.</p>
      </div>

      <div class="shop-quiz-grid">
        <form id="shop-routine-form" class="card grid md-2" novalidate>
          <label>
            Tipo di pelle
            <select name="skin" required>
              <option value="">Seleziona</option>
              <option value="secca">Secca</option>
              <option value="mista">Mista</option>
              <option value="sensibile">Sensibile</option>
            </select>
          </label>

          <label>
            Obiettivo principale
            <select name="goal" required>
              <option value="">Seleziona</option>
              <option value="idratazione">Idratazione</option>
              <option value="luminosita">Luminosita</option>
              <option value="lenitivo">Lenitivo / anti-rossori</option>
            </select>
          </label>

          <label>
            Texture preferita
            <select name="texture" required>
              <option value="">Seleziona</option>
              <option value="leggera">Leggera</option>
              <option value="ricca">Ricca</option>
            </select>
          </label>

          <fieldset class="shop-checks" style="grid-column:1/-1;">
            <legend>Preferenze formula</legend>
            <label><input type="checkbox" name="prefs" value="sensitive" /> Pelle sensibile</label>
            <label><input type="checkbox" name="prefs" value="vegan" /> Opzioni vegan</label>
            <label><input type="checkbox" name="prefs" value="fragrance" /> Senza profumo</label>
          </fieldset>

          <button class="btn" type="submit">Genera routine</button>
          <p id="shop-routine-status" class="wizard-status" aria-live="polite"></p>
        </form>

        <aside id="shop-routine-result" class="card card--soft" aria-live="polite">
          <h3>La tua routine apparira qui</h3>
          <p class="muted">Compila il quiz per ricevere una proposta con massimo 3 prodotti per step e varianti in base alle preferenze formula.</p>
        </aside>
      </div>
    </section>

    <section class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Assistente guidato</p>
        <h2>Consigli personalizzati, senza overload</h2>
        <p class="section-intro">L assistente propone massimo 3 opzioni motivate, ricorda preferenze locali e consente il passaggio a beauty advisor umano.</p>
      </div>

      <div class="shop-ai-grid">
        <form id="shop-ai-form" class="card grid md-2" novalidate>
          <label>
            Cosa cerchi oggi
            <select name="concern" required>
              <option value="">Seleziona bisogno</option>
              <option value="glow">Glow naturale</option>
              <option value="hydration">Idratazione profonda</option>
              <option value="calm">Pelle reattiva / rossori</option>
            </select>
          </label>
          <label>
            Finish desiderato
            <select name="finish" required>
              <option value="">Seleziona finish</option>
              <option value="natural">Naturale</option>
              <option value="dewy">Luminoso</option>
              <option value="light">Leggero</option>
            </select>
          </label>
          <label style="grid-column:1/-1;">
            Ingrediente da evitare
            <select name="avoid" required>
              <option value="none">Nessuno</option>
              <option value="fragrance">Parfum / fragranze</option>
            </select>
          </label>
          <button class="btn" type="submit">Suggerisci 3 opzioni</button>
          <a class="btn btn--ghost" href="mailto:advisor@lifestylecreme.demo">Parla con una beauty advisor</a>
          <p id="shop-ai-status" class="wizard-status" aria-live="polite"></p>
        </form>

        <aside id="shop-ai-result" class="card card--soft" aria-live="polite">
          <h3>Proposte AI</h3>
          <p class="muted">Seleziona i parametri per ricevere opzioni coerenti con il bisogno indicato.</p>
        </aside>
      </div>
    </section>

    <section class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Messaggi di fiducia</p>
        <h2>Prove credibili, urgenza misurata</h2>
        <p class="section-intro">Claim con fonte e nota di contesto, senza countdown artificiali o promesse non verificabili.</p>
      </div>

      <div class="shop-proof-grid">
        <article class="card" data-reveal>
          <h3>Claim</h3>
          <p>Tra i piu scelti da clienti con pelle sensibile (dato demo).</p>
          <p><strong>Fonte:</strong> panel interno demo su 120 risposte.</p>
          <p class="muted">Nota: dato non clinico, percezione utente auto-riportata.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Claim</h3>
          <p>Routine glow piu acquistata oggi (dato demo).</p>
          <p><strong>Fonte:</strong> analytics e-commerce demo giornata corrente.</p>
          <p class="muted">Nota: il volume puo variare in base a promozioni e traffico.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Claim</h3>
          <p>Formula testata solo dove esplicitamente indicato.</p>
          <p><strong>Fonte:</strong> documentazione tecnica prodotto (placeholder demo).</p>
          <p class="muted">Nota: badge mostrato solo con supporto documentale.</p>
        </article>
      </div>
    </section>

    <section class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Live e lanci</p>
        <h2>Lancio routine con countdown reale</h2>
        <p class="section-intro">Countdown reale al prossimo drop, clip live/replay e set limitato con CTA dedicata.</p>
      </div>

      <div class="shop-live-grid">
        <article class="card" data-reveal>
          <h3>Drop: Glow Routine Set</h3>
          <p id="shop-drop-countdown" class="shop-countdown" aria-live="polite">Calcolo countdown...</p>
          <p class="muted">Se il live e concluso, trovi replay e acquisto set nello stesso flusso.</p>
          <div class="hero-actions">
            <a class="btn" href="/shop/products">Acquista la routine</a>
            <a class="btn btn--ghost" href="/shop/products">Guarda replay</a>
          </div>
        </article>

        <article class="card card--soft" data-reveal>
          <h3>Checkout senza attrito</h3>
          <p>Express pay disponibile in checkout Shopify con tempi di consegna e reso sempre visibili.</p>
          <p><strong>Consegna:</strong> 48-72h demo | <strong>Reso:</strong> 30 giorni demo</p>
          <a class="btn btn--ghost" href="/shop/cart">Vai al checkout</a>
        </article>
      </div>
    </section>

    <section id="best-seller" class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Best seller</p>
        <h2>Estetica premium, percorso di acquisto chiaro</h2>
        <p class="section-intro">Look editoriale, CTA leggibili e policy su spedizione/resi sempre in evidenza.</p>
      </div>

      <div class="grid md-3">
        {featured.map((product) => <ProductCard product={product} />)}
      </div>

      <p class="shop-delivery-line">Spedizione demo 48-72h · Reso demo 30 giorni · Express pay disponibile al checkout.</p>
      <p id="shop-feedback" class="wizard-status" aria-live="polite"></p>
    </section>
  </div>

  <script is:inline set:html={cartScript}></script>
  <script is:inline define:vars={{ products, dropDateISO }}>
    (() => {
      const allProducts = Array.isArray(products) ? products : [];
      const bySlug = (slug) => allProducts.find((item) => item.slug === slug);
      const searchText = (item) => `${item.name} ${item.shortDescription} ${item.category} ${item.inci}`.toLowerCase();
      const keywordMatch = (item, regex) => regex.test(searchText(item));
      const pickByKeywords = (regex, fallbackIndex = 0) =>
        allProducts.find((item) => keywordMatch(item, regex)) || allProducts[fallbackIndex] || null;
      const fragranceFree = (item) => !/parfum/i.test(item.inci || '');
      const veganFriendly = (item) => !/cera alba|beeswax|honey/i.test(item.inci || '');
      const ensureCartApi = () => {
        if (window.shopCart && typeof window.shopCart.addToCart === 'function') return window.shopCart;

        const key = 'shop-cart';
        const readCart = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(key) || '[]');
            return Array.isArray(parsed) ? parsed : [];
          } catch {
            return [];
          }
        };
        const writeCart = (cart) => localStorage.setItem(key, JSON.stringify(Array.isArray(cart) ? cart : []));
        const itemKey = (item) => [item.slug, item.variant || 'base'].join('::');
        const addToCart = (product) => {
          const cart = readCart();
          const found = cart.find((item) => itemKey(item) === itemKey(product));
          if (found) found.qty = (Number(found.qty) || 1) + 1;
          else cart.push({ ...product, qty: 1 });
          writeCart(cart);
        };

        window.shopCart = { readCart, writeCart, addToCart };
        return window.shopCart;
      };
      const parsePayload = (button) => {
        try {
          const parsed = JSON.parse(button.dataset.product || '{}');
          if (parsed && parsed.slug) return parsed;
        } catch {
          // Fallback to dataset fields below.
        }

        const slug = (button.dataset.slug || '').trim();
        if (!slug) return null;

        return {
          slug,
          name: button.dataset.name || slug,
          price: Number.parseFloat(button.dataset.price || '0'),
          category: button.dataset.category || '',
          image: button.dataset.image || '',
          shortDescription: button.dataset.shortDescription || '',
          inci: button.dataset.inci || '',
          variantId: button.dataset.variantId || undefined,
          variantTitle: button.dataset.variantTitle || undefined
        };
      };

      const feedback = document.getElementById('shop-feedback');
      const addBySlug = (slug, variant = '') => {
        const item = bySlug(slug);
        if (!item) return;
        const payload = variant ? { ...item, variant } : item;
        ensureCartApi().addToCart(payload);
        if (feedback) feedback.textContent = `${payload.name}${variant ? ` · ${variant}` : ''} aggiunto al carrello (demo).`;
      };

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const quick = target.closest('[data-quick-add]');
        if (quick instanceof HTMLButtonElement) {
          addBySlug(quick.dataset.quickAdd || '', quick.dataset.variant || '');
          return;
        }

        const button = target.closest('.add-to-cart');
        if (!(button instanceof HTMLButtonElement)) return;

        try {
          const payload = parsePayload(button);
          if (!payload) throw new Error('Invalid product payload');
          ensureCartApi().addToCart(payload);
          if (feedback) feedback.textContent = `${payload.name} aggiunto al carrello (demo).`;
        } catch {
          if (feedback) feedback.textContent = 'Errore: impossibile aggiungere il prodotto al carrello.';
        }
      });

      const proofEl = document.getElementById('shop-proof-soft');
      if (proofEl) {
        const dynamicCount = 24 + new Date().getHours() * 3;
        proofEl.textContent = `Oggi ${dynamicCount}+ persone hanno scelto una routine skincare (dato demo).`;
      }

      const routineForm = document.getElementById('shop-routine-form');
      const routineStatus = document.getElementById('shop-routine-status');
      const routineResult = document.getElementById('shop-routine-result');

      const buildRoutine = ({ skin, goal, texture, prefs }) => {
        const cleanser = pickByKeywords(/clean|wash|deterg|gentle|delicate/i, 0);
        const toner = pickByKeywords(/tonic|toner|mist/i, 1);
        const serum = pickByKeywords(/serum|siero|essence|repair/i, 2);
        const glowPick = pickByKeywords(/glow|bright|radiance|vitamin/i, 3);
        const calmPick = pickByKeywords(/calm|soothe|sensitive|lenit|repair/i, 4);
        const hydrationPick = pickByKeywords(/hydr|hyal|moist|comfort/i, 5);
        const richPick = pickByKeywords(/rich|cream|crema|body|butter/i, 6);

        const focusPick = goal === 'lenitivo' || skin === 'sensibile' ? calmPick : goal === 'luminosita' ? glowPick : hydrationPick;
        const morning = [cleanser, toner, goal === 'luminosita' ? focusPick : serum].filter(Boolean);
        const evening = [cleanser, goal === 'lenitivo' || skin === 'sensibile' ? calmPick : serum, texture === 'ricca' ? richPick : toner].filter(Boolean);

        const bundle = [morning[0], morning[2], evening[1]]
          .filter(Boolean)
          .filter((item, index, array) => array.findIndex((candidate) => candidate.slug === item.slug) === index);

        const sensitiveAlt = allProducts.filter((item) => fragranceFree(item)).slice(0, 3);
        const veganAlt = allProducts.filter((item) => veganFriendly(item)).slice(0, 3);
        const fragAlt = allProducts.filter((item) => fragranceFree(item)).slice(0, 3);

        return {
          morning,
          evening,
          bundle,
          alternatives: {
            sensitive: prefs.includes('sensitive') ? sensitiveAlt : [],
            vegan: prefs.includes('vegan') ? veganAlt : [],
            fragrance: prefs.includes('fragrance') ? fragAlt : []
          }
        };
      };

      const renderItems = (items, label = '') => {
        if (!items.length) return '';
        const title = label ? `<h4>${label}</h4>` : '';
        return `<div class="shop-routine-block">${title}<ul>${items
          .map((item) => `<li>${item.name} <button type="button" class="btn btn--ghost" data-quick-add="${item.slug}">Aggiungi</button></li>`)
          .join('')}</ul></div>`;
      };

      const renderAlternatives = (alternatives) => {
        const rows = [];
        if (alternatives.sensitive.length) rows.push(`<h5>Pelle sensibile</h5>${renderItems(alternatives.sensitive, '')}`);
        if (alternatives.vegan.length) rows.push(`<h5>Opzioni vegan</h5>${renderItems(alternatives.vegan, '')}`);
        if (alternatives.fragrance.length) rows.push(`<h5>Senza profumo</h5>${renderItems(alternatives.fragrance, '')}`);
        return rows.length ? `<div class="shop-alt-wrap">${rows.join('')}</div>` : '<p class="muted">Nessuna preferenza aggiuntiva selezionata.</p>';
      };

      if (routineForm instanceof HTMLFormElement && routineResult instanceof HTMLElement) {
        routineForm.addEventListener('submit', (event) => {
          event.preventDefault();
          if (!routineForm.checkValidity()) {
            routineForm.reportValidity();
            if (routineStatus) routineStatus.textContent = 'Compila i campi per generare una routine personalizzata.';
            return;
          }

          const formData = new FormData(routineForm);
          const skin = String(formData.get('skin') || '');
          const goal = String(formData.get('goal') || '');
          const texture = String(formData.get('texture') || '');
          const prefs = formData.getAll('prefs').map((value) => String(value));

          const routine = buildRoutine({ skin, goal, texture, prefs });
          const bundlePrice = routine.bundle.reduce((sum, item) => sum + item.price, 0);

          routineResult.innerHTML = `
            <h3>Routine consigliata</h3>
            <p class="muted">Profilo selezionato: ${skin} · obiettivo: ${goal} · texture: ${texture}</p>
            <div class="shop-routine-columns">
              ${renderItems(routine.morning, 'Routine mattina')}
              ${renderItems(routine.evening, 'Routine sera')}
            </div>
            <div class="shop-bundle-box">
              <h4>Bundle suggerito</h4>
              <ul>${routine.bundle.map((item) => `<li>${item.name}</li>`).join('')}</ul>
              <p><strong>Totale bundle demo: EUR ${bundlePrice.toFixed(2)}</strong></p>
              <button type="button" class="btn" data-quick-add="${routine.bundle[0]?.slug || ''}">Aggiungi il primo step</button>
            </div>
            <div>
              <h4>Alternative selezionate</h4>
              ${renderAlternatives(routine.alternatives)}
            </div>
          `;

          if (routineStatus) routineStatus.textContent = 'Routine generata con successo (demo).';
        });
      }

      const aiForm = document.getElementById('shop-ai-form');
      const aiStatus = document.getElementById('shop-ai-status');
      const aiResult = document.getElementById('shop-ai-result');
      const aiKey = 'shop-ai-preferences';

      const recommendByConcern = (concern) => {
        const concernRegex = concern === 'calm' ? /calm|soothe|sensitive|repair|gentle|delicate/i : concern === 'hydration' ? /hydr|hyal|moist|comfort/i : /glow|bright|radiance|vitamin/i;
        const matches = allProducts.filter((item) => keywordMatch(item, concernRegex));
        const uniques = [...matches];

        allProducts.forEach((item) => {
          if (uniques.length >= 3) return;
          if (!uniques.some((candidate) => candidate.slug === item.slug)) uniques.push(item);
        });

        return uniques.slice(0, 3);
      };

      const readSavedPrefs = () => {
        try {
          return JSON.parse(localStorage.getItem(aiKey) || '{}');
        } catch {
          return {};
        }
      };

      const savePrefs = (prefs) => {
        try {
          localStorage.setItem(aiKey, JSON.stringify(prefs));
        } catch {
          // Ignore storage errors.
        }
      };

      if (aiForm instanceof HTMLFormElement && aiResult instanceof HTMLElement) {
        const saved = readSavedPrefs();
        if (saved.concern) aiForm.elements.concern.value = saved.concern;
        if (saved.finish) aiForm.elements.finish.value = saved.finish;
        if (saved.avoid) aiForm.elements.avoid.value = saved.avoid;

        aiForm.addEventListener('submit', (event) => {
          event.preventDefault();
          if (!aiForm.checkValidity()) {
            aiForm.reportValidity();
            if (aiStatus) aiStatus.textContent = 'Seleziona i parametri per ricevere le proposte.';
            return;
          }

          const formData = new FormData(aiForm);
          const concern = String(formData.get('concern') || '');
          const finish = String(formData.get('finish') || '');
          const avoid = String(formData.get('avoid') || 'none');

          savePrefs({ concern, finish, avoid });

          let picks = recommendByConcern(concern);
          if (avoid === 'fragrance') picks = picks.filter((item) => fragranceFree(item));
          if (!picks.length) picks = allProducts.slice(0, 3);
          picks = picks.slice(0, 3);

          const reasons = {
            glow: 'Scelti per migliorare la luminosita in modo progressivo.',
            hydration: 'Scelti per mantenere idratazione lungo tutta la routine.',
            calm: 'Scelti per una routine essenziale e ben tollerata.'
          };

          aiResult.innerHTML = `
            <h3>3 opzioni suggerite</h3>
            <p class="muted">${reasons[concern] || 'Selezione personalizzata.'} Finish richiesto: ${finish}.</p>
            <ul>
              ${picks
                .map(
                  (item) =>
                    `<li><strong>${item.name}</strong> - ${item.shortDescription} <button type="button" class="btn btn--ghost" data-quick-add="${item.slug}">Aggiungi</button></li>`
                )
                .join('')}
            </ul>
            <p class="muted">Preferenze ricordate: ${avoid === 'fragrance' ? 'senza fragranze' : 'nessuna esclusione ingredienti'}.</p>
          `;

          if (aiStatus) aiStatus.textContent = 'Proposte aggiornate. Se vuoi, puoi passare a un beauty advisor umano.';
        });
      }

      const dropCountdown = document.getElementById('shop-drop-countdown');
      if (dropCountdown) {
        const launchDate = new Date(dropDateISO);
        const updateDropTimer = () => {
          const diff = launchDate.getTime() - Date.now();
          if (diff <= 0) {
            dropCountdown.textContent = 'Live concluso: replay disponibile ora.';
            return;
          }

          const days = Math.floor(diff / 86400000);
          const hours = Math.floor((diff % 86400000) / 3600000);
          const minutes = Math.floor((diff % 3600000) / 60000);
          const seconds = Math.floor((diff % 60000) / 1000);
          dropCountdown.textContent = `Prossimo drop reale tra ${days}g ${hours}h ${minutes}m ${seconds}s`;
        };

        updateDropTimer();
        setInterval(updateDropTimer, 1000);
      }
    })();
  </script>
</MainLayout>
