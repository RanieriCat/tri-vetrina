---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout template="psy" title="Contatti | Studio di Psicologia" description="Contatta lo studio per un colloquio conoscitivo.">
  <section class="section container grid md-2">
    <div>
      <h1>Contatti</h1>
      <p>Compila il modulo per richiedere un primo colloquio conoscitivo.</p>
      <form class="card grid" id="psy-form" novalidate>
        <label>Nome <input name="nome" required /></label>
        <label>Email <input name="email" type="email" required /></label>
        <label>Messaggio <textarea name="messaggio" required rows="5"></textarea></label>
        <button class="btn" type="submit">Invia richiesta</button>
        <p id="psy-status" aria-live="polite"></p>
      </form>
    </div>
    <div>
      <h2>FAQ</h2>
      <div class="card">
        <h3>Quanto dura un colloquio?</h3>
        <p>Circa 50 minuti, in studio oppure online.</p>
        <h3>Con quale frequenza si svolgono gli incontri?</h3>
        <p>Di norma settimanale, con possibilità di personalizzazione.</p>
        <h3>Il colloquio conoscitivo è vincolante?</h3>
        <p>No, serve a capire insieme obiettivi e metodo.</p>
      </div>
    </div>
  </section>
  <script is:inline>
    const form = document.getElementById('psy-form');
    const status = document.getElementById('psy-status');
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!form.checkValidity()) return;
      status.textContent = 'Messaggio inviato con successo. Ti risponderemo entro 48 ore.';
      form.reset();
    });
  </script>
</MainLayout>
