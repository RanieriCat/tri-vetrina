---
import BentoFeatures from '@/components/BentoFeatures.astro';
import LeadWizard from '@/components/LeadWizard.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import ProfileHero from '@/components/ProfileHero.astro';
import TrustSection from '@/components/TrustSection.astro';
---
<MainLayout template="psy" title="Studio di Psicologia | Dott.ssa Elena Guidi" description="Supporto psicologico individuale per adulti e giovani adulti.">
  <ProfileHero
    template="psy"
    kicker="Tri Vetrina / Psicologia"
    title="Uno spazio digitale accogliente per il primo passo."
    description="Interfaccia mobile-first con tono calmo, gerarchie pulite e call-to-action progressive per ridurre l attrito iniziale."
    primaryCta={{ href: '#psy-lead', label: 'Richiedi contatto' }}
    secondaryCta={{ href: '/psy/contatti', label: 'Vai ai contatti' }}
    note="Contenuto informativo demo: nessuna promessa clinica o risultato garantito."
  />

  <TrustSection
    eyebrow="Trust-first"
    title="Indicatori di fiducia chiari"
    intro="Placeholder per referenze, metriche e testimonianze utili a mostrare il layout senza dati sensibili o non verificabili."
    logos={['Studio Hub', 'Community Care', 'Wellbeing Lab', 'Network Salute']}
    metrics={[
      { value: 'XX+', label: 'Colloqui demo / mese', note: 'Placeholder' },
      { value: 'YY%', label: 'Richieste completate', note: 'Placeholder' },
      { value: 'ZZ h', label: 'Tempo medio risposta', note: 'Placeholder' },
      { value: 'AA/5', label: 'Percezione chiarezza', note: 'Placeholder' }
    ]}
    quote="Placeholder testimonianza: tono rispettoso, passaggi comprensibili, contatto semplice."
    quoteAuthor="Utente demo"
  />

  <BentoFeatures
    eyebrow="Bento care"
    title="Percorsi in griglia modulare"
    intro="Una card dominante orienta la scelta iniziale, le card secondarie approfondiscono modalita e strumenti."
    items={[
      {
        icon: 'ANS',
        title: 'Gestione ansia e stress',
        body: 'Card dominante con focus su ritmo, regolazione e strumenti quotidiani.',
        dominant: true
      },
      {
        icon: 'REL',
        title: 'Relazioni e confini',
        body: 'Percorso su comunicazione assertiva e riconoscimento dei pattern.'
      },
      {
        icon: 'AUT',
        title: 'Autostima e identita',
        body: 'Lavoro graduale sulla narrazione personale e sulle risorse interne.'
      },
      {
        icon: 'ONL',
        title: 'Sessioni in presenza o online',
        body: 'Scelta del canale in base al contesto e alle preferenze.'
      },
      {
        icon: 'RES',
        title: 'Risorse pratiche',
        body: 'Materiali brevi per supportare continuita tra un colloquio e l altro.'
      }
    ]}
  />

  <section class="section container" data-reveal>
    <div class="section-head">
      <p class="eyebrow">Organic layout</p>
      <h2>Sezione asimmetrica a bassa complessita</h2>
      <p class="section-intro">Composizione bilanciata: area principale per orientamento, colonna laterale per micro-rassicurazioni.</p>
    </div>

    <div class="organic-layout">
      <article class="card hover-lift" data-reveal>
        <h3>Come si svolge il primo incontro</h3>
        <p>Introduzione al contesto personale e agli obiettivi percepiti.</p>
        <p>Definizione di priorita realistiche e primo piano di lavoro condiviso.</p>
        <p>Scelta del ritmo degli incontri in base a disponibilita e bisogno.</p>
      </article>

      <aside class="organic-side">
        <article class="card card--soft hover-lift" data-reveal>
          <h3>Microcopy rispettoso</h3>
          <p>Linguaggio sobrio, non giudicante, orientato alla chiarezza del processo.</p>
        </article>
        <article class="card card--soft hover-lift" data-reveal>
          <h3>Iconografia morbida</h3>
          <p>Segnali visivi discreti per accompagnare la lettura, non per distrarre.</p>
        </article>
      </aside>
    </div>
  </section>

  <LeadWizard
    id="psy-lead"
    title="Richiedi un primo colloquio"
    intro="Mini wizard 3 step con validazione base: nome, email e area di bisogno."
    needs={['Gestione ansia', 'Difficolta relazionali', 'Autostima e transizioni']}
    submitLabel="Invia richiesta"
  />
</MainLayout>

