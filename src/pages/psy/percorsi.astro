---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout template="psy" title="Percorsi | Studio di Psicologia" description="Approcci terapeutici e percorsi disponibili.">
  <section class="section container">
    <h1>Percorsi terapeutici</h1>
    <div class="grid md-3">
      <article class="card"><h2>Gestione ansia e stress</h2><p>Tecniche pratiche, psicoeducazione e monitoraggio delle risposte corporee.</p></article>
      <article class="card"><h2>Autostima e identità</h2><p>Riconoscimento di schemi ricorrenti e costruzione di nuove narrazioni personali.</p></article>
      <article class="card"><h2>Difficoltà relazionali</h2><p>Migliorare comunicazione assertiva, confini e consapevolezza emotiva.</p></article>
    </div>
  </section>
</MainLayout>
