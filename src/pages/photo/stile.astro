---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout template="photo" title="Stile | Luca Ferretti" description="Approccio creativo, direzione artistica e workflow fotografico demo.">
  <section class="section container" data-reveal>
    <div class="section-head">
      <p class="eyebrow">Stile</p>
      <h1>Direzione creativa</h1>
      <p class="section-intro">Metodo orientato a coerenza visiva: concept, esecuzione e output pronti per web e social.</p>
    </div>

    <div class="organic-layout">
      <article class="card hover-lift" data-reveal>
        <h2>Linee guida estetiche</h2>
        <p>Luce: naturale o controllata in base al tono del progetto.</p>
        <p>Colori: palette bilanciate con contrasto leggibile su mobile.</p>
        <p>Composizione: ritmo visivo pulito, alternanza dettaglio/contesto.</p>
      </article>

      <aside class="organic-side">
        <article class="card card--soft hover-lift" data-reveal>
          <h3>Pre-produzione</h3>
          <p>Brief, moodboard e checklist tecnica condivisa.</p>
        </article>
        <article class="card card--soft hover-lift" data-reveal>
          <h3>Post-produzione</h3>
          <p>Selezione, color grading e naming file consistente.</p>
        </article>
      </aside>
    </div>
  </section>
</MainLayout>
