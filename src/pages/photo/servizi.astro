---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout template="photo" title="Servizi | Luca Ferretti" description="Pacchetti fotografici demo per brand, eventi e ritratti professionali.">
  <section class="section container" data-reveal>
    <div class="section-head">
      <p class="eyebrow">Servizi</p>
      <h1>Pacchetti fotografici</h1>
      <p class="section-intro">Offerta modulare: produzione, post-produzione e consegna. I dati economici sono placeholder.</p>
    </div>

    <div class="bento">
      <article class="card bento-card bento-card--dominant hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">PRO</span>
        <h2>Brand Story Pack</h2>
        <p>Shooting completo per campagne digitali: moodboard, shotlist, sessione e selezione finale.</p>
        <p><strong>Placeholder: EUR XXX</strong></p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">EVT</span>
        <h3>Event Coverage</h3>
        <p>Copertura evento con recap in 24-48h (placeholder).</p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">POR</span>
        <h3>Ritratto Pro</h3>
        <p>Sessione ritratto per profili professionali e team.</p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">PRD</span>
        <h3>Pack Prodotto</h3>
        <p>Scatti e-commerce orientati a conversione visuale.</p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">RAW</span>
        <h3>Post-produzione</h3>
        <p>Color grading e export multi-formato ottimizzato.</p>
      </article>
    </div>
  </section>
</MainLayout>
