---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout template="photo" title="Servizi | Luca Ferretti" description="Pacchetti fotografici demo per brand, eventi e ritratti professionali.">
  <section class="section container" data-reveal>
    <div class="section-head">
      <p class="eyebrow">Servizi</p>
      <h1>Pacchetti fotografici</h1>
      <p class="section-intro">Offerta modulare: pre-produzione, shooting, post-produzione e consegna. I prezzi sono placeholder demo.</p>
    </div>

    <div class="bento">
      <article class="card bento-card bento-card--dominant hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">PRO</span>
        <h2>Brand Story Pack</h2>
        <p>Produzione completa per campagne digitali: moodboard, shotlist, sessione guidata e selezione finale.</p>
        <p><strong>Da EUR XXX (placeholder)</strong></p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">EVT</span>
        <h3>Event Coverage</h3>
        <p>Copertura evento con selezione rapida e recap in 24-48h (placeholder).</p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">POR</span>
        <h3>Ritratto Pro</h3>
        <p>Sessione ritratto per professionisti, team e personal brand.</p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">PRD</span>
        <h3>Pack Prodotto</h3>
        <p>Scatti prodotto per e-commerce e ADV orientati alla conversione.</p>
      </article>
      <article class="card bento-card hover-lift" data-reveal>
        <span class="bento-icon" aria-hidden="true">RAW</span>
        <h3>Post-produzione</h3>
        <p>Color grading, ritocco e export multi-formato pronto per i canali richiesti.</p>
      </article>
    </div>
  </section>
</MainLayout>
