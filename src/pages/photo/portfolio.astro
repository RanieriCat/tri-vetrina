---
import MainLayout from '@/layouts/MainLayout.astro';

const projects = [
  {
    title: 'Editoriale urbano',
    tag: 'Fashion / Street',
    image: 'https://picsum.photos/seed/photo-editorial-01/1400/1000',
    note: 'Palette contrastata e luce naturale guidata.',
    size: 'l'
  },
  {
    title: 'Campagna prodotto',
    tag: 'Brand / E-commerce',
    image: 'https://picsum.photos/seed/photo-brand-02/1200/900',
    note: 'Set minimale pensato per valorizzare texture e dettagli.',
    size: 'm'
  },
  {
    title: 'Ritratto creativo',
    tag: 'Portrait',
    image: 'https://picsum.photos/seed/photo-portrait-03/1000/1300',
    note: 'Composizione dinamica con direzione posa naturale.',
    size: 's'
  },
  {
    title: 'Evento live',
    tag: 'Event',
    image: 'https://picsum.photos/seed/photo-event-04/1400/1000',
    note: 'Sequenza narrativa per recap social, stampa e ufficio comunicazione.',
    size: 'm'
  },
  {
    title: 'Food storytelling',
    tag: 'Food / Lifestyle',
    image: 'https://picsum.photos/seed/photo-food-05/1200/900',
    note: 'Luce morbida e ritmo visivo per una serie coerente.',
    size: 's'
  },
  {
    title: 'Team portraits',
    tag: 'Corporate',
    image: 'https://picsum.photos/seed/photo-team-06/1400/1000',
    note: 'Look professionale e naturale, gestito direttamente in sede.',
    size: 'm'
  },
  {
    title: 'Campaign still life',
    tag: 'Commercial',
    image: 'https://picsum.photos/seed/photo-campaign-07/1400/1000',
    note: 'Dettaglio prodotto e composizione essenziale in stile premium.',
    size: 'm'
  }
];
---
<MainLayout template="photo" title="Portfolio | Luca Ferretti" description="Selezione lavori per brand, eventi, ritratto e storytelling visivo.">
  <section class="section container" data-reveal>
    <div class="section-head">
      <p class="eyebrow">Portfolio</p>
      <h1 class="photo-section-title">Selezione lavori in mosaic editoriale</h1>
      <p class="section-intro">Griglia modulare con tile L/M/S, pensata per valorizzare serie diverse senza perdere coerenza.</p>
    </div>

    <div class="mosaic" aria-label="Portfolio fotografico in mosaic">
      {projects.map((project, index) => (
        <article class={`mosaic-tile mosaic-tile--${project.size} photo-texture photo-breath ${index % 4 === 0 ? 'tilt-accent' : ''}`} data-reveal data-tilt={index % 4 === 0 ? 'true' : undefined}>
          <img
            src={project.image}
            alt={project.title}
            width="1400"
            height="1000"
            loading="lazy"
            decoding="async"
          />
          <div class="mosaic-meta">
            <p>{project.tag}</p>
            <h2>{project.title}</h2>
            <p>{project.note}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    (() => {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const canTilt = !reduceMotion && window.matchMedia('(pointer: fine)').matches;
      if (!canTilt) return;

      const tiltTargets = Array.from(document.querySelectorAll('[data-tilt]'));
      tiltTargets.forEach((target) => {
        if (!(target instanceof HTMLElement)) return;

        const onMove = (event) => {
          const rect = target.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          target.style.setProperty('--tilt-y', `${(x * 5).toFixed(2)}deg`);
          target.style.setProperty('--tilt-x', `${(-y * 5).toFixed(2)}deg`);
        };

        const reset = () => {
          target.style.setProperty('--tilt-y', '0deg');
          target.style.setProperty('--tilt-x', '0deg');
        };

        target.addEventListener('pointermove', onMove);
        target.addEventListener('pointerleave', reset);
      });
    })();
  </script>
</MainLayout>
