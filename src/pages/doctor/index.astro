---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout
  template="doctor"
  title="Dott. Marco Rinaldi | Cardiologia"
  description="Specialista in cardiologia clinica con approccio preventivo e umano."
  footerText="Questo sito è una demo. Le informazioni non sostituiscono il parere medico."
>
  <section class="hero container">
    <h1>Dott. Marco Rinaldi</h1>
    <p>Specialista in Cardiologia clinica e prevenzione cardiovascolare.</p>
    <a href="#prenota" class="btn">Prenota una visita</a>
  </section>

  <section id="servizi" class="section container">
    <h2>Servizi offerti</h2>
    <div class="grid md-3">
      <article class="card"><h3>Visita cardiologica</h3><p>Valutazione completa di anamnesi, fattori di rischio e sintomi.</p></article>
      <article class="card"><h3>ECG a riposo</h3><p>Esame rapido per monitorare ritmo e attività elettrica del cuore.</p></article>
      <article class="card"><h3>Follow-up prevenzione</h3><p>Piano personalizzato su alimentazione, attività fisica e monitoraggio.</p></article>
    </div>
  </section>

  <section id="prenota" class="section container">
    <h2>Prenota appuntamento</h2>
    <form id="doctor-form" class="card grid md-2" novalidate>
      <label>Nome e cognome <input required name="nome" /></label>
      <label>Email <input required type="email" name="email" /></label>
      <label>Telefono <input required name="telefono" /></label>
      <label>Data e ora preferita <input required type="datetime-local" name="slot" /></label>
      <label style="grid-column:1/-1;">Messaggio <textarea name="messaggio" rows="4"></textarea></label>
      <button class="btn" type="submit">Invia richiesta</button>
      <p id="doctor-form-status" aria-live="polite"></p>
    </form>
  </section>

  <section id="contatti" class="section container">
    <h2>Contatti</h2>
    <div class="grid md-2">
      <div class="card">
        <p><strong>Telefono:</strong> +39 02 5555 7777</p>
        <p><strong>Email:</strong> studio@rinaldicuore.it</p>
        <p><strong>Indirizzo:</strong> Via Verdi 10, Milano</p>
      </div>
      <iframe class="card" title="Mappa studio medico" src="https://maps.google.com/maps?q=milano&t=&z=13&ie=UTF8&iwloc=&output=embed" style="min-height:260px;width:100%;border:0;"></iframe>
    </div>
  </section>
  <script is:inline>
    const form = document.getElementById('doctor-form');
    const statusEl = document.getElementById('doctor-form-status');
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        statusEl.textContent = 'Controlla i campi obbligatori prima di inviare.';
        return;
      }
      statusEl.textContent = 'Richiesta inviata. Ti ricontatteremo entro 24 ore.';
      form.reset();
    });
  </script>
</MainLayout>
