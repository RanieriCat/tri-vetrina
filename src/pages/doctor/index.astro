---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout
  template="doctor"
  title="Dott. Marco Rinaldi | Cardiologia"
  description="Cardiologia clinica e preventiva con percorso chiaro: prenotazione, televisita, visita in sede e follow-up."
  footerText="Demo informativa: contenuti illustrativi, non sostituiscono il parere medico e non gestiscono emergenze."
>
  <div class="doctor-page">
    <section class="section container doctor-hero-section" data-reveal>
      <div class="doctor-trust-grid">
        <article class="card doctor-hero-card" data-reveal>
          <p class="eyebrow">Cardiologia clinica</p>
          <h1>Dott. Marco Rinaldi</h1>
          <p class="doctor-lede">
            Assistenza cardiologica con comunicazione chiara, tempi definiti e continuita tra prima visita, controlli e follow-up.
          </p>

          <ul class="doctor-kpi-row" aria-label="Informazioni rapide">
            <li class="doctor-kpi">
              <strong>Struttura</strong>
              <span>Poliambulatorio Aurora, Milano</span>
            </li>
            <li class="doctor-kpi">
              <strong>Tempi medi</strong>
              <span>Prima visita demo: entro 72 ore</span>
            </li>
            <li class="doctor-kpi">
              <strong>Contatti rapidi</strong>
              <span>+39 02 5555 7777</span>
            </li>
          </ul>

          <div class="doctor-quick-contact" aria-label="Contatti veloci">
            <a class="btn btn--ghost doctor-action-btn" href="tel:+390255557777">Chiama lo studio</a>
            <a class="btn btn--ghost doctor-action-btn" href="mailto:studio@rinaldicuore.it">Scrivi email</a>
          </div>

          <a class="btn doctor-action-btn" href="#prenota">Prenota visita</a>
          <p class="doctor-note">Per urgenze con sintomi acuti chiama il 112 o recati al Pronto Soccorso.</p>
        </article>

        <aside class="card doctor-hero-media doctor-calm-hover" data-reveal>
          <img
            src="https://images.unsplash.com/photo-1584515933487-779824d29309?auto=format&fit=crop&w=1200&q=80"
            alt="Medico durante consulto in ambulatorio"
            width="1200"
            height="900"
            loading="eager"
            decoding="async"
          />
          <div class="doctor-hero-badges" aria-label="Credibilita e contesto">
            <p><strong>Equipe:</strong> Cardiologo + infermiere di triage</p>
            <p><strong>Certificazioni:</strong> Aggiornamento ECM continuo (placeholder)</p>
            <p><strong>Affiliazioni:</strong> Rete cardiologica territoriale (placeholder)</p>
          </div>
        </aside>
      </div>

      <div class="card card--soft doctor-proof-strip" data-reveal>
        <div class="doctor-proof-list">
          <p><strong>Recensioni contestualizzate:</strong> controlli pressione, follow-up prevenzione e supporto su stile di vita (placeholder).</p>
          <p><strong>Approccio clinico:</strong> indicazioni comprensibili, documentazione leggibile e piano condiviso con il paziente.</p>
        </div>
      </div>
    </section>

    <section class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Percorsi operativi</p>
        <h2>Scegli il percorso giusto in pochi secondi</h2>
        <p class="section-intro">Ogni card porta a un obiettivo preciso: prenotazione, specialista, referti, televisita o urgenze.</p>
      </div>

      <div class="doctor-task-grid" aria-label="Percorsi rapidi">
        <a class="card doctor-task doctor-calm-hover" href="#prenota" data-reveal>
          <h3>Prenota</h3>
          <p>Invia una richiesta guidata con canale preferito e fascia oraria.</p>
        </a>
        <a class="card doctor-task doctor-calm-hover" href="#specialista" data-reveal>
          <h3>Trova uno specialista</h3>
          <p>Prestazioni e condizioni trattate con struttura informativa chiara.</p>
        </a>
        <a class="card doctor-task doctor-calm-hover" href="#referti" data-reveal>
          <h3>Esami e referti</h3>
          <p>Tempi indicativi, preparazione e accesso semplice ai referti demo.</p>
        </a>
        <a class="card doctor-task doctor-calm-hover" href="#televisita" data-reveal>
          <h3>Televisita</h3>
          <p>Dal primo orientamento al controllo in studio in un flusso unico.</p>
        </a>
        <a class="card doctor-task doctor-calm-hover" href="#urgenze" data-reveal>
          <h3>Urgenze / dove andare</h3>
          <p>Indicazioni rapide su quando attivare i canali di emergenza.</p>
        </a>
      </div>
    </section>

    <section id="televisita" class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Percorso ibrido</p>
        <h2>Dal primo orientamento al follow-up</h2>
        <p class="section-intro">Un flusso continuo: questionario sintomi, triage, televisita, visita in studio e monitoraggio nel tempo.</p>
      </div>

      <ol class="doctor-journey" aria-label="Percorso paziente ibrido">
        <li class="card doctor-journey-step" data-reveal>
          <h3>1. Questionario sintomi</h3>
          <p>Raccolta iniziale guidata per orientare il canale piu adatto.</p>
        </li>
        <li class="card doctor-journey-step" data-reveal>
          <h3>2. Triage clinico</h3>
          <p>Valutazione preliminare della priorita con supporto infermieristico.</p>
        </li>
        <li class="card doctor-journey-step" data-reveal>
          <h3>3. Televisita</h3>
          <p>Consulto video iniziale per inquadramento e definizione dei passaggi successivi.</p>
        </li>
        <li class="card doctor-journey-step" data-reveal>
          <h3>4. Visita in studio</h3>
          <p>Approfondimento clinico quando necessario, con eventuali esami strumentali.</p>
        </li>
        <li class="card doctor-journey-step" data-reveal>
          <h3>5. Follow-up continuo</h3>
          <p>Monitoraggio nel tempo con indicazioni pratiche e documentazione condivisa.</p>
        </li>
      </ol>

      <div class="doctor-ai-grid">
        <form id="doctor-ai-form" class="card grid md-2" novalidate data-reveal>
          <h3 style="grid-column:1/-1;">Assistente orientativo</h3>
          <p class="doctor-note" style="grid-column:1/-1;">
            Questo strumento non effettua diagnosi: suggerisce il percorso e prevede sempre un passaggio umano.
          </p>

          <label>
            Sintomo principale
            <select name="symptom" required>
              <option value="">Seleziona sintomo</option>
              <option value="dolore_toracico">Dolore toracico o affanno</option>
              <option value="palpitazioni">Palpitazioni ricorrenti</option>
              <option value="pressione">Pressione non controllata</option>
              <option value="controllo">Controllo programmato</option>
            </select>
          </label>

          <label>
            Intensita percepita
            <select name="urgency" required>
              <option value="">Seleziona livello</option>
              <option value="alta">Alta</option>
              <option value="media">Media</option>
              <option value="bassa">Bassa</option>
            </select>
          </label>

          <label style="grid-column:1/-1;">
            Da quanto tempo
            <select name="duration" required>
              <option value="">Seleziona durata</option>
              <option value="meno_24h">Da meno di 24 ore</option>
              <option value="2_7gg">2-7 giorni</option>
              <option value="oltre_7gg">Da oltre 7 giorni</option>
            </select>
          </label>

          <button class="btn doctor-action-btn" type="submit">Ricevi orientamento</button>
          <p id="doctor-ai-status" class="wizard-status" aria-live="polite"></p>
        </form>

        <aside class="card card--soft" data-reveal>
          <h3>Trasparenza AI</h3>
          <ul>
            <li>Non sostituisce il medico e non produce diagnosi cliniche.</li>
            <li>Se il rischio percepito e alto, invita subito ai canali di emergenza.</li>
            <li>Se non urgente, propone triage umano entro tempi definiti.</li>
          </ul>
        </aside>
      </div>
    </section>

    <section id="specialista" class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Contenuto clinico chiaro</p>
        <h2>Prestazioni spiegate in modo leggibile</h2>
        <p class="section-intro">Formato standard utile per pazienti e SEO: quando serve, come si svolge, preparazione, rischi e tempi.</p>
      </div>

      <div class="doctor-clinical-grid">
        <article class="card doctor-clinical-card" data-reveal>
          <h3>Visita cardiologica con ECG</h3>
          <dl>
            <dt>Quando serve</dt>
            <dd>In presenza di sintomi compatibili o per controlli programmati su fattori di rischio.</dd>
            <dt>Come si svolge</dt>
            <dd>Anamnesi, visita, ECG a riposo e definizione del piano successivo.</dd>
            <dt>Preparazione</dt>
            <dd>Portare esami precedenti e terapia in corso; evitare sforzi intensi immediatamente prima.</dd>
            <dt>Rischi / controindicazioni</dt>
            <dd>Valutazione non invasiva; eventuali limiti vengono discussi durante il colloquio.</dd>
            <dt>Tempi e referti</dt>
            <dd>Durata demo 30-40 minuti, referto orientativo nella stessa giornata.</dd>
          </dl>
        </article>

        <article class="card doctor-clinical-card" data-reveal>
          <h3>Follow-up prevenzione cardiovascolare</h3>
          <dl>
            <dt>Quando serve</dt>
            <dd>Per monitorare nel tempo pressione, abitudini e aderenza al piano concordato.</dd>
            <dt>Come si svolge</dt>
            <dd>Revisione indicatori, obiettivi progressivi e adattamento delle raccomandazioni.</dd>
            <dt>Preparazione</dt>
            <dd>Annotare parametri domiciliari e farmaci assunti nelle ultime settimane.</dd>
            <dt>Rischi / controindicazioni</dt>
            <dd>Approccio conservativo e personalizzato; eventuali alert portano ad approfondimenti mirati.</dd>
            <dt>Tempi e referti</dt>
            <dd>Check demo 20-30 minuti con piano sintetico condiviso a fine visita.</dd>
          </dl>
        </article>
      </div>
    </section>

    <section id="referti" class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Referti e documenti</p>
        <h2>Referti chiari, tempi chiari</h2>
      </div>

      <div class="doctor-referti-grid">
        <article class="card" data-reveal>
          <h3>Tempi indicativi</h3>
          <p>Referti demo disponibili entro 24-72 ore in base al tipo di accertamento.</p>
          <p>Consegna tramite area riservata demo o ritiro in studio.</p>
          <a class="btn btn--ghost doctor-action-btn" href="#contatti">Chiedi info sui referti</a>
        </article>

        <article class="card card--soft" data-reveal>
          <h3>Privacy dati clinici</h3>
          <p>Nel modulo raccogliamo solo i dati minimi necessari alla gestione della richiesta.</p>
          <p>I dati demo non sono condivisi con terzi e vengono usati solo per contatto operativo.</p>
        </article>
      </div>
    </section>

    <section class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Percorsi per ruolo</p>
        <h2>Esperienze dedicate a pazienti, medici e aziende</h2>
      </div>

      <div class="doctor-role-grid">
        <article class="card doctor-calm-hover" data-reveal>
          <h3>Pazienti</h3>
          <p>Prenotazione, esami, referti e supporto post-visita in un unico flusso.</p>
        </article>
        <article class="card doctor-calm-hover" data-reveal>
          <h3>Medici</h3>
          <p>Accesso operativo, invio documentazione e coordinamento del follow-up clinico.</p>
        </article>
        <article class="card doctor-calm-hover" data-reveal>
          <h3>Aziende</h3>
          <p>Convenzioni e programmi di prevenzione per team e welfare aziendale.</p>
        </article>
      </div>
    </section>

    <section id="urgenze" class="section container" data-reveal>
      <div class="card doctor-urgency" data-reveal>
        <h2>Urgenze: dove andare</h2>
        <ul>
          <li>Dolore toracico intenso, dispnea importante o sintomi neurologici: chiama subito il 112.</li>
          <li>Per situazioni non acute ma prioritarie: attiva il triage telefonico dello studio.</li>
          <li>Per controlli programmabili: usa il percorso prenotazione o televisita.</li>
        </ul>
      </div>
    </section>

    <section id="prenota" class="section container" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Prenotazione</p>
        <h2>Prenota visita o televisita</h2>
        <p class="section-intro">Modulo essenziale, campi leggibili e validazione chiara in linea con principi WCAG.</p>
      </div>

      <div class="doctor-booking-grid">
        <form id="doctor-booking-form" class="card grid md-2" novalidate data-reveal>
          <label>Nome e cognome <input name="name" required autocomplete="name" /></label>
          <label>Email <input name="email" type="email" required autocomplete="email" /></label>
          <label>Telefono <input name="phone" required autocomplete="tel" /></label>
          <label>Modalita preferita
            <select name="mode" required>
              <option value="">Seleziona modalita</option>
              <option value="studio">Visita in studio</option>
              <option value="video">Televisita</option>
            </select>
          </label>
          <label style="grid-column:1/-1;">Motivo principale
            <select name="reason" required>
              <option value="">Seleziona motivo</option>
              <option value="prima_visita">Prima visita cardiologica</option>
              <option value="controllo">Controllo periodico</option>
              <option value="pressione">Monitoraggio pressione</option>
            </select>
          </label>
          <button class="btn doctor-action-btn" type="submit">Invia richiesta</button>
          <p id="doctor-booking-status" class="wizard-status" aria-live="polite"></p>
        </form>

        <aside class="card card--soft" data-reveal>
          <h3>Privacy e sicurezza visibili</h3>
          <p>I dati richiesti servono solo a organizzare il contatto, non a formulare diagnosi.</p>
          <p>Quando necessario, il percorso viene preso in carico da un professionista umano.</p>
          <p class="doctor-note">Nessun dato demo viene usato per profilazione commerciale.</p>
        </aside>
      </div>
    </section>

    <section id="contatti" class="section container" data-reveal>
      <div class="doctor-referti-grid">
        <article class="card" data-reveal>
          <h2>Contatti studio</h2>
          <p><strong>Telefono:</strong> +39 02 5555 7777</p>
          <p><strong>Email:</strong> studio@rinaldicuore.it</p>
          <p><strong>Indirizzo:</strong> Via Verdi 10, Milano</p>
          <p class="doctor-note">Orari demo: lun-ven 09:00-18:00</p>
        </article>

        <div class="card" data-reveal style="padding: 0; overflow: hidden;">
          <iframe
            class="iframe-map"
            title="Mappa studio medico"
            src="https://maps.google.com/maps?q=milano&t=&z=13&ie=UTF8&iwloc=&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const bookingForm = document.getElementById('doctor-booking-form');
      const bookingStatus = document.getElementById('doctor-booking-status');

      if (bookingForm instanceof HTMLFormElement) {
        bookingForm.addEventListener('submit', (event) => {
          event.preventDefault();

          if (!bookingForm.checkValidity()) {
            bookingForm.reportValidity();
            if (bookingStatus) bookingStatus.textContent = 'Controlla i campi obbligatori prima di inviare.';
            return;
          }

          if (bookingStatus) bookingStatus.textContent = 'Richiesta inviata (demo). Ti ricontattiamo entro 24 ore lavorative.';
          bookingForm.reset();
        });
      }

      const aiForm = document.getElementById('doctor-ai-form');
      const aiStatus = document.getElementById('doctor-ai-status');

      if (aiForm instanceof HTMLFormElement) {
        aiForm.addEventListener('submit', (event) => {
          event.preventDefault();

          if (!aiForm.checkValidity()) {
            aiForm.reportValidity();
            if (aiStatus) aiStatus.textContent = 'Completa i campi per ricevere un orientamento.';
            return;
          }

          const formData = new FormData(aiForm);
          const symptom = String(formData.get('symptom') || '');
          const urgency = String(formData.get('urgency') || '');
          const duration = String(formData.get('duration') || '');

          let message = 'Orientamento: prenota un triage telefonico entro 24 ore per definire il percorso.';

          if (urgency === 'alta' || (symptom === 'dolore_toracico' && duration === 'meno_24h')) {
            message = 'Orientamento: possibile priorita alta. Chiama subito il 112 o recati in Pronto Soccorso.';
          } else if (urgency === 'media' || symptom === 'palpitazioni') {
            message = 'Orientamento: consigliata una televisita di inquadramento nelle prossime 24-48 ore.';
          }

          if (aiStatus) {
            aiStatus.textContent = `${message} Nota: questo strumento non effettua diagnosi medica.`;
          }
        });
      }
    })();
  </script>
</MainLayout>
